---
import { existsSync } from 'node:fs'
import path from 'node:path'
import { POSTS_CONFIG } from '~/config.ts'
import FloatingContactCard from '~/components/base/FloatingContactCard.astro'
import FaqSection from '~/components/base/FaqSection.astro'
import HeroMetric from '~/components/base/HeroMetric.astro'
import ProductsSlider from '~/components/base/ProductsSlider.astro'
import ReviewsSection from '~/components/base/ReviewsSection.astro'
import ServicesList from '~/components/base/ServicesList.astro'
import HomeLayout from '~/layouts/HomeLayout.astro'
import SectionDivider from '~/components/base/SectionDivider.astro'
import SocialLink from '~/components/base/SocialLink.astro'
import List from '~/components/posts/card/List.astro'
import { getNumPosts, getPinnedPosts } from '~/lib/data'
import { getSiteData } from '~/lib/site-data'
import { truncateText } from '~/lib/utils'

const { size, type } = POSTS_CONFIG.homePageConfig
const siteData = await getSiteData()
const uberClientId = siteData.site.uberClientId ?? import.meta.env.PUBLIC_UBER_CLIENT_ID
const phoneDigits = siteData.nap.phone.replace(/\D/g, '')
const phoneHref = siteData.nap.wap ? `https://wa.me/${phoneDigits}` : `tel:${phoneDigits}`
const generatedLocationMapLightURL = '/generated/location-map-light.avif'
const generatedLocationMapDarkURL = '/generated/location-map-dark.avif'
const generatedLocationMapLightMobileURL = '/generated/location-map-light-mobile.avif'
const generatedLocationMapDarkMobileURL = '/generated/location-map-dark-mobile.avif'
const generatedLocationMapLightPath = path.resolve(process.cwd(), 'public/generated/location-map-light.avif')
const generatedLocationMapDarkPath = path.resolve(process.cwd(), 'public/generated/location-map-dark.avif')
const generatedLocationMapLightMobilePath = path.resolve(process.cwd(), 'public/generated/location-map-light-mobile.avif')
const generatedLocationMapDarkMobilePath = path.resolve(process.cwd(), 'public/generated/location-map-dark-mobile.avif')
const shouldUseGeneratedLocationMaps =
  existsSync(generatedLocationMapLightPath) &&
  existsSync(generatedLocationMapDarkPath) &&
  existsSync(generatedLocationMapLightMobilePath) &&
  existsSync(generatedLocationMapDarkMobilePath)
const locationDescription = siteData.homeLabels.locationDescriptionTemplate.replace('{city}', siteData.site.city)

let showPosts = []
const pinnedPosts = await getPinnedPosts()
const hasPinnedPosts = pinnedPosts.length > 0
if (hasPinnedPosts) {
  showPosts = pinnedPosts
} else {
  showPosts = await getNumPosts(size)
}
---

<HomeLayout title={siteData.site.seo_title} description={siteData.site.description} useTitleAsIs>
  <div class="relative z-[1]">
    <div class="py-8 pb-10 px-6 sm:px-8">
      <h1 class="flex flex-col gap-2">
        <span class="text-muted-foreground font-light text-base sm:text-lg block tracking-wide text-balance">
          {siteData.hero.eyebrow}
        </span>
        <span class="text-4xl sm:text-5xl tracking-tight">{siteData.hero.brand}</span>
      </h1>
      <div class="home-hero-copy mt-4 text-base leading-7 text-muted-foreground text-pretty">
        <p>{truncateText(siteData.hero.tagline, 150)}</p>
      </div>
      <div class="mt-6 grid gap-6 md:flex md:items-start md:gap-x-5">
        <div class="flex items-start gap-3 md:min-w-0 md:flex-1">
          <span class="icon-[mdi--office-building] block size-6 shrink-0 text-primary"></span>
          <div>
            <p class="text-sm font-medium text-muted-foreground">{siteData.nap.company}</p>
            <p class="text-sm text-green-700">{siteData.nap.status}</p>
          </div>
        </div>
        <div
          aria-hidden="true"
          class="home-nap-divider hidden md:block self-stretch w-px shrink-0"
        ></div>
        <div class="flex items-start gap-3 md:min-w-0 md:flex-1">
          <span class="icon-[mdi--map-marker] block size-6 shrink-0 text-primary"></span>
          <p class="text-sm text-muted-foreground">{siteData.nap.address}</p>
        </div>
        <div
          aria-hidden="true"
          class="home-nap-divider hidden md:block self-stretch w-px shrink-0"
        ></div>
        <div class="flex items-start gap-3 md:min-w-0 md:flex-1">
          <a
            href={phoneHref}
            target={siteData.nap.wap ? '_blank' : undefined}
            rel={siteData.nap.wap ? 'noreferrer' : undefined}
            class="inline-flex items-start gap-3 text-left transition hover:text-primary"
          >
            <span class:list={[siteData.nap.wap ? 'icon-[ri--whatsapp-fill]' : 'icon-[mdi--phone]', 'mt-0.5 size-6 shrink-0 text-foreground']}></span>
            <div>
              <p class="text-xs tracking-wide text-muted-foreground">{siteData.homeLabels.contactUs}</p>
              <p class="text-sm font-medium text-muted-foreground">{siteData.nap.phone}</p>
            </div>
          </a>
        </div>
      </div>
      <div class="mt-6 flex gap-6">
        <HeroMetric
          icon={siteData.heroMetric.icon}
          primaryValue={siteData.heroMetric.primaryValue}
          primaryLabel={siteData.heroMetric.primaryLabel}
          secondaryValue={siteData.heroMetric.secondaryValue}
          secondaryLabel={siteData.heroMetric.secondaryLabel}
        />
        {
          siteData.socialLinks.map((item) => {
            return <SocialLink href={item.url} icon={item.icon} aria-label={`${siteData.homeLabels.socialLinkAriaLabelPrefix} ${item.name}`} count={item.count} label={item.label} />
          })
        }
      </div>
    </div>
    {
      siteData.homeSections.map((section) => (
        <>
          <SectionDivider />
          <div class="py-8 pb-10 px-6 sm:px-8">
            {
              section.key === 'reviews' && section.items ? (
                <ReviewsSection title={section.title} description={section.description} reviews={section.items} metric={siteData.heroMetric} />
              ) : section.key === 'products' && section.products ? (
                <>
                  <ProductsSlider
                    title={section.title}
                    description={section.description}
                    products={section.products.map((product) => ({
                      imageSrc: product.image.src,
                      name: product.name,
                      category: product.category,
                      price: product.price,
                      url: product.url,
                    }))}
                  />
                </>
              ) : section.key === 'services' && section.services ? (
                <>
                  <h2 class="text-2xl sm:text-3xl tracking-tight">{section.title}</h2>
                  <p class="text-muted-foreground mb-6 mt-1">{section.description}</p>
                  <ServicesList services={section.services} />
                </>
              ) : section.key === 'faq' && section.faqs ? (
                <>
                  <FaqSection title={section.title} description={section.description} faqs={section.faqs} />
                </>
              ) : (
                <>
                  <div class:list={['mb-6', section.key === 'location' && 'grid gap-6 md:grid-cols-[1fr_auto] md:items-start']}>
                    <div>
                      <h2 class="text-2xl sm:text-3xl tracking-tight">{section.title}</h2>
                      <p class="text-muted-foreground mt-1">
                        {section.key === 'location' ? locationDescription : section.description}
                      </p>
                    </div>
                    {
                      section.key === 'location' && uberClientId && section.latitude !== undefined && section.longitude !== undefined && (
                        <a
                          href={`https://m.uber.com/ul/?client_id=${encodeURIComponent(uberClientId)}&action=setPickup&pickup=my_location&dropoff[latitude]=${section.latitude}&dropoff[longitude]=${section.longitude}`}
                          target="_blank"
                          rel="noreferrer"
                          class="flex min-w-[220px] items-start gap-4 rounded-2xl border border-border/60 bg-card/40 p-4 transition hover:bg-accent/40"
                        >
                          <span class="icon-[mdi--car] mt-0.5 size-6 shrink-0 text-foreground"></span>
                          <div>
                            <p class="font-medium text-foreground">{siteData.homeLabels.uberCtaTitle}</p>
                            <p class="text-muted-foreground text-sm">{siteData.homeLabels.uberCtaDescription}</p>
                          </div>
                        </a>
                      )
                    }
                  </div>
                  {
                    section.key === 'location' && shouldUseGeneratedLocationMaps ? (
                      <>
                        <a
                          href={section.gmn_url ?? '#'}
                          target="_blank"
                          rel="noreferrer"
                          title={siteData.homeLabels.openMapTitle}
                          class="block overflow-hidden border border-border/50"
                        >
                          <picture data-location-map>
                            <source
                              media="(max-width: 767px)"
                              data-light-srcset={generatedLocationMapLightMobileURL}
                              data-dark-srcset={generatedLocationMapDarkMobileURL}
                              width="378"
                              height="378"
                            />
                            <img
                              data-light-src={generatedLocationMapLightURL}
                              data-dark-src={generatedLocationMapDarkURL}
                              alt={section.mapAlt ?? `${section.title} map`}
                              width="700"
                              height="350"
                              loading="eager"
                              fetchpriority="high"
                              class="home-location-map w-full object-cover"
                            />
                          </picture>
                        </a>
                        <script is:inline>
                          (() => {
                            const syncLocationMaps = () => {
                              const isDark = document.documentElement.classList.contains('dark')
                              document.querySelectorAll('[data-location-map]').forEach((picture) => {
                                if (!(picture instanceof HTMLPictureElement)) return
                                const source = picture.querySelector('source')
                                const image = picture.querySelector('img')
                                if (!(source instanceof HTMLSourceElement) || !(image instanceof HTMLImageElement)) return

                                const nextSourceSet = isDark ? source.dataset.darkSrcset : source.dataset.lightSrcset
                                const nextSrc = isDark ? image.dataset.darkSrc : image.dataset.lightSrc

                                if (nextSourceSet) {
                                  source.srcset = nextSourceSet
                                }
                                if (nextSrc) {
                                  const srcChanged = image.getAttribute('src') !== nextSrc
                                  if (srcChanged) {
                                    image.src = nextSrc
                                  }
                                }
                              })
                            }

                            document.addEventListener('theme:change', syncLocationMaps)
                            document.addEventListener('astro:page-load', syncLocationMaps)
                            syncLocationMaps()
                          })()
                        </script>
                      </>
                    ) : section.key === 'location' && section.map_url && (
                      <a
                        href={section.gmn_url ?? '#'}
                        target="_blank"
                        rel="noreferrer"
                        title={siteData.homeLabels.openMapTitle}
                        class="block overflow-hidden border border-border/50"
                      >
                        <img
                          src={section.map_url.src}
                          alt={section.mapAlt ?? `${section.title} map`}
                          width="702"
                          height="351"
                          loading="eager"
                          fetchpriority="high"
                          class="home-location-map w-full object-cover"
                        />
                      </a>
                    )
                  }
                </>
              )
            }
          </div>
        </>
      ))
    }
    <SectionDivider />
    <div class="py-8 pb-10 px-6 sm:px-8">
      <h2 class="text-2xl sm:text-3xl tracking-tight">{siteData.homeLabels.postsTitle}</h2>
      <p class="text-muted-foreground mb-6 mt-1">
        {hasPinnedPosts ? siteData.homeLabels.pinnedLabel : siteData.homeLabels.recentLabel}
        {showPosts.length} {siteData.homeLabels.postsSummarySuffix}
      </p>
      <List posts={showPosts} {type} coverLayout={POSTS_CONFIG.homePageConfig?.coverLayout} useHomeThumbs animate={false} />
    </div>
  </div>
  <FloatingContactCard phone={siteData.nap.phone} wap={siteData.nap.wap} />
</HomeLayout>
