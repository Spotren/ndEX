---
type ServiceItem = {
  name: string
  type: string
  price?: string
}

type Props = {
  services: ServiceItem[]
}

const { services }: Props = Astro.props
---

<div>
  {
    services.map((service) => (
      <article class="group flex items-center justify-between py-3 border-b border-border/30 last:border-b-0">
        <div class="flex-1 pr-4">
          <div class="text-base font-medium text-muted-foreground/90 transition-colors duration-200 group-hover:text-primary line-clamp-1">
            {service.name}
          </div>
        </div>
        <div class="flex-shrink-0 text-sm text-muted-foreground/90 transition-colors duration-200 group-hover:text-primary whitespace-nowrap font-mono">
          {service.type}
          {service.price ? ` ${service.price}` : ''}
        </div>
      </article>
    ))
  }
</div>
